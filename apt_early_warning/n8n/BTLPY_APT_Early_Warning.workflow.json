        "id": "1dd1ff80-f046-4ca2-9014-5d6838cf4dc1",
        "name": "Telegram"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "language": "javaScript",
          "jsCode": "const raw = String($env.TELEGRAM_CHAT_IDS ?? $env.TELEGRAM_CHAT_ID ?? '').trim();\nconst chatIds = raw\n  .split(/[\\s,]+/)\n  .map((s) => s.trim())\n  .filter(Boolean);\n\nif (!chatIds.length) {\n  throw new Error('Missing TELEGRAM_CHAT_IDS (comma-separated) or TELEGRAM_CHAT_ID');\n}\n\nconst title = $json?.title ?? '';\nconst message = $json?.message ?? '';\nconst actions = Array.isArray($json?.actions) ? $json.actions : [];\n\nconst text =\n  title +\n  \"\\n\\n\" +\n  message +\n  \"\\n\\nHành động đề xuất:\\n- \" +\n  (actions.length ? actions.join(\"\\n- \") : '(không có)');\n\nreturn chatIds.map((chatId) => ({ json: { chatId, text } }));"
        },
        "type": "n8n-nodes-base.code",
