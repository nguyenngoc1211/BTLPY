          "messages": {
            "values": [
              {
                "content": "=Bạn là SOC analyst. Viết cảnh báo Telegram ngắn gọn bằng tiếng Việt từ JSON sau.\n- Nêu: stage, confidence, severity, src/dst, và 3 hành động đề xuất.\nChỉ trả về JSON hợp lệ, không kèm chữ khác. Trả về đúng dạng:\n{\n  \"title\": \"...\",\n  \"message\": \"...\",\n  \"actions\": [\"...\", \"...\", \"...\"]\n}\n\nJSON đầu vào:\n{{ JSON.stringify($node[\"HTTP Request\"].json, null, 2) }}"
              }
            ]
          },
          "jsonOutput": true,
          "builtInTools": {},
          "options": {}
        },
        "type": "@n8n/n8n-nodes-langchain.googleGemini",
        "typeVersion": 1.1,
        "position": [
          704,
          -32
        ],
        "id": "dff15f1e-596b-44fb-9bc0-d75e50f5b94e",
        "name": "Message a model"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "language": "javaScript",
          "jsCode": "const data = $input.item.json;\n\n// Gemini node often returns the model output as a JSON string in:\n//   data.content.parts[0].text\nconst text = data?.content?.parts?.[0]?.text ?? data?.text ?? '';\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    title: 'UNPARSED_GEMINI_OUTPUT',\n    message: text || JSON.stringify(data),\n    actions: [],\n  };\n}\n\nreturn { json: parsed };"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
