    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = String($env.TELEGRAM_CHAT_IDS ?? $env.TELEGRAM_CHAT_ID ?? '').trim();\nconst chatIds = raw.split(/[\\s,]+/).map((s) => s.trim()).filter(Boolean);\nconst llm = $json.llm ?? {};\nconst title = llm.title ?? 'APT ALERT';\nconst message = llm.message ?? $json.summary;\nconst actions = Array.isArray(llm.actions) ? llm.actions : [];\nconst text = title + '\\n\\n' + message + '\\n\\nHành động đề xuất:\\n- ' + (actions.length ? actions.join('\\n- ') : '(không có)');\nif (!chatIds.length) {\n  return [];\n}\nreturn chatIds.map((chatId) => ({ json: { chatId, text } }));"
      },
