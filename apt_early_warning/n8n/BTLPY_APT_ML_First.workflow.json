        },
        "messages": {
          "values": [
            {
              "content": "=Bạn là SOC analyst. Viết cảnh báo Telegram ngắn gọn bằng tiếng Việt từ JSON sau.\\n- Nêu: label/stage, confidence, severity, src/dst và 3 hành động đề xuất.\\nChỉ trả về JSON hợp lệ, không kèm chữ khác. Trả về đúng dạng:\\n{\\n  \\\"title\\\": \\\"...\\\",\\n  \\\"message\\\": \\\"...\\\",\\n  \\\"actions\\\": [\\\"...\\\", \\\"...\\\", \\\"...\\\"]\\n}\\n\\nJSON đầu vào:\\n{{ JSON.stringify($node[\"HTTP Request /score\"].json, null, 2) }}"
            }
          ]
        },
        "jsonOutput": true,
        "builtInTools": {},
        "options": {}
      },
      "id": "ea93df6d-59e8-4ce8-b30f-e1926278757f",
      "name": "Message a model",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        672,
        416
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "YSJ4llq850jdPUVX",
          "name": "Google Gemini(PaLM) Api account 2"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nconst text = data?.content?.parts?.[0]?.text ?? data?.text ?? '';\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    title: 'UNPARSED_GEMINI_OUTPUT',\n    message: text || JSON.stringify(data),\n    actions: [],\n  };\n}\nreturn { json: parsed };"
      },
      "id": "f4c93394-5908-49ad-9d78-11f96b3f5a1a",
      "name": "Parse Gemini JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        -352
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const scoreFromNode = $node[\"HTTP Request /score\"]?.json ?? {};\n  const scoreFromInput = ($json?.score && typeof $json.score === \"object\") ? $json.score : {};\n  const score = Object.keys(scoreFromInput).length ? scoreFromInput : scoreFromNode;\n\n  const llm = ($json && typeof $json === \"object\") ? $json : {};\n\n  const label = String(score.stage ?? score.label ?? \"Unknown\");\n  const confidenceNum = Number(score.confidence ?? 0);\n  const confidence = Number.isFinite(confidenceNum) ? confidenceNum : 0;\n  const severity = String(score.severity ?? \"LOW\");\n\n  return {\n    json: {\n      ok: true,\n      workflow: \"BTLPY_APT_ML_First\",\n      decision: String(score.decision ?? \"ALERT\"),\n      severity,\n      label,\n      confidence,\n      proba: score.proba ?? {},\n      flow_meta: score.flow_meta ?? null,\n      score,\n      llm,\n      summary: `[APT ALERT] label=${label} confidence=${confidence.toFixed(4)} severity=${severity}`,\n      suggested_actions: Array.isArray(llm.actions) ? llm.actions : [],\n      ts: new Date().toISOString()\n    }\n  };"
      },
      "id": "10a74949-e548-4f63-b6ef-a466fd10379f",
      "name": "Build ALERT Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        -352
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const score = $json;\nreturn {\n  json: {\n    ok: true,\n    workflow: 'BTLPY_APT_ML_First',\n    decision: score.decision,\n    severity: score.severity,\n    label: score.stage,\n    confidence: score.confidence,\n    proba: score.proba ?? {},\n    flow_meta: score.flow_meta ?? null,\n    summary: `[NO ALERT] label=${score.stage} confidence=${Number(score.confidence).toFixed(4)}`,\n    suggested_actions: [\n      'Tiếp tục giám sát lưu lượng liên quan',\n      'Lưu event vào kho log để phục vụ correlation',\n      'Đánh giá lại threshold nếu có nhiều false-positive/false-negative'\n    ],\n    ts: new Date().toISOString()\n  }\n};"
      },
      "id": "17c761fd-cac5-43ee-a535-a77eb26f1664",
      "name": "Build NO_ALERT Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
