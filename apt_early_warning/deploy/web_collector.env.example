# Copy to: /etc/apt_early_warning_web_collector.env

# Path to JSONL web-flow events (your app/proxy writes here).
WEB_EVENTS_PATH=/var/log/apt_web/events.jsonl

# Score then forward only ALERTs.
SCORE_URL=http://127.0.0.1:8000/score
N8N_WEBHOOK=http://127.0.0.1:5678/webhook/apt-ingest
ALERTS_DB_PATH=/var/log/apt_web/alerts.db

VERBOSE=1
