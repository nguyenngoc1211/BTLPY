# Copy to: /etc/web_early_warning_scoring.env

# Bind address for uvicorn.
HOST=0.0.0.0
PORT=8000

# Model bundle path (production-safe calibrated option).
BUNDLE_PATH=/home/sealorl/BTLPY/web_early_warning/model_out_flowfeatures/lgbm_web16_prod_safe_1970train.joblib

# Optional policy overrides.
ALERT_LABELS=WebAttack
# Calibrated threshold from benign-future holdout (~5% false-alert budget on that holdout).
ALERT_MIN_CONF_HIGH_IMPACT=0.999988
ALERT_MIN_CONF_NON_BENIGN=0.999988
