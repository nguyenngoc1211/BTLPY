# Copy to: /etc/apt_early_warning_web_log_parser.env

# Input access log (nginx/apache; combined or json-line).
WEB_ACCESS_LOG_PATH=/var/log/nginx/access.log

# Output events for web collector.
WEB_EVENTS_PATH=/var/log/apt_web/events.jsonl

# Aggregation tuning.
WEB_FLOW_WINDOW_SEC=20
WEB_FLOW_MIN_REQUESTS=3
WEB_FLOW_FLUSH_SEC=3

VERBOSE=1
